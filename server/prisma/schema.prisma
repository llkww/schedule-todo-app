generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  username     String
  email        String     @unique
  passwordHash String
  schedules    Schedule[]
  tags         Tag[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Schedule {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  startTime   DateTime?
  endTime     DateTime?
  dueTime     DateTime?
  completed   Boolean        @default(false)
  importance  String         @default("MEDIUM")
  urgency     String         @default("MEDIUM")
  status      String         @default("PENDING")
  tags        ScheduleTag[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId])
  @@index([dueTime])
  @@index([status])
  @@index([importance, urgency])
}

model Tag {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String
  schedules ScheduleTag[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model ScheduleTag {
  scheduleId String
  tagId      String
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([scheduleId, tagId])
  @@index([tagId])
}
